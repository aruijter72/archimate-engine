<?xml version="1.0" encoding="UTF-8"?>
<archimate:model xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                 xmlns:archimate="http://www.archimatetool.com/archimate"
                 name="ESB Tender — IJsselgemeenten" id="id-1ot0wawvv6ty6" version="5.0">
  <documentation>ArchiMate 3 model for the European procurement (aanbesteding) of an Enterprise Service Bus (ESB) solution by IJsselgemeenten (gemeentelijk samenwerkingsverband). The tender follows EU Directive 2014/24/EU (public sector procurement) and the Dutch Aanbestedingswet 2012. The model covers the full tender lifecycle — from market consultation through contract management — and describes the ESB solution requirements across the Business, Application, and Technology layers.</documentation>
  <folder name="Business" id="id-xcwo9xmxbnzx8" type="business">
    <element xsi:type="archimate:BusinessActor" name="IJsselgemeenten" id="biz-actor-ijssel">
      <documentation>Gemeentelijk samenwerkingsverband (shared municipal service organisation) acting as the contracting authority (aanbestedende dienst) under EU Directive 2014/24/EU. Represents the consortium of municipalities in the IJssel region.</documentation>
      <property key="Organisatietype" value="Gemeenschappelijke regeling (Wgr)"/>
      <property key="Rol in aanbesteding" value="Aanbestedende dienst"/>
      <property key="Toepasselijk recht" value="EU Directive 2014/24/EU · Aanbestedingswet 2012"/>
    </element>
    <element xsi:type="archimate:BusinessActor" name="Marktpartijen (Inschrijvers)" id="biz-actor-markt">
      <documentation>Commercial vendors and system integrators that respond to the tender by submitting bids for the ESB solution. Must meet selection criteria (uitsluitingsgronden, geschiktheidseisen) and award criteria (gunningscriteria).</documentation>
      <property key="Type" value="Leverancier / Dienstverlener"/>
      <property key="Vereiste kwalificaties" value="ISO 27001, NEN 7510 (indien van toepassing), referentieopdrachten"/>
    </element>
    <element xsi:type="archimate:BusinessActor" name="Centrale Inkooporganisatie" id="biz-actor-cpb">
      <documentation>Central procurement unit within IJsselgemeenten or mandated to assist, responsible for procedure management and compliance with procurement law.</documentation>
      <property key="Type" value="Interne ondersteunende eenheid"/>
    </element>
    <element xsi:type="archimate:BusinessActor" name="Privacy &amp; Security Officer (CISO/FG)" id="biz-actor-pia">
      <documentation>Functionaris Gegevensbescherming (DPO) and CISO who validate the Privacy Impact Assessment (PIA/DPIA) and information security requirements embedded in the tender specification.</documentation>
      <property key="Grondslag" value="AVG / GDPR Art. 35 (DPIA), BIO (Baseline Informatiebeveiliging Overheid)"/>
    </element>
    <element xsi:type="archimate:BusinessRole" name="Aanbestedende Dienst" id="biz-role-aanbestedende">
      <documentation>Legal role of the contracting authority under EU procurement law. Responsible for publishing the contract notice, conducting the procedure, and awarding the contract in compliance with EU Directive 2014/24/EU.</documentation>
      <property key="EU Richtlijn" value="2014/24/EU Art. 2(1)"/>
    </element>
    <element xsi:type="archimate:BusinessRole" name="Inschrijver" id="biz-role-inschrijver">
      <documentation>Role of an economic operator that submits a tender in response to the contract notice. Subject to exclusion grounds (art. 2.86-2.87 Aanbestedingswet) and suitability requirements.</documentation>
    </element>
    <element xsi:type="archimate:BusinessRole" name="Beoordelingscommissie" id="biz-role-beoordelaar">
      <documentation>Evaluation committee composed of domain experts, legal advisors, and IT specialists who score tenders on the award criteria (BPKV — Best Price-Quality Ratio).</documentation>
      <property key="Gunningscriterium" value="BPKV (Beste Prijs-Kwaliteitsverhouding)"/>
      <property key="Grondslag" value="Art. 2.115 Aanbestedingswet 2012"/>
    </element>
    <element xsi:type="archimate:BusinessRole" name="Contractmanager" id="biz-role-contractmgr">
      <documentation>Responsible for managing the ESB contract post-award, including SLA monitoring, change management, and escalation.</documentation>
    </element>
    <element xsi:type="archimate:BusinessCollaboration" name="Aanbestedingsteam IJsselgemeenten" id="biz-collab-aanbestedingsteam">
      <documentation>Cross-functional collaboration between IJsselgemeenten's procurement unit, IT department, legal advisors, CISO/FG, and business stakeholders working together to execute the ESB tender.</documentation>
    </element>
    <element xsi:type="archimate:BusinessInterface" name="TenderNed / TED Portal" id="biz-iface-tenderned">
      <documentation>Digital publication and submission portal. TenderNed is the Dutch national platform (mandatory for NL contracting authorities); TED (Tenders Electronic Daily) is the EU-wide publication journal for contracts above the EU threshold.</documentation>
      <property key="Platform NL" value="TenderNed (www.tenderned.nl)"/>
      <property key="Platform EU" value="TED (Tenders Electronic Daily, EU OJ/S)"/>
      <property key="EU Drempelwaarde (2024)" value="EUR 221.000 (leveringen/diensten centrale overheid)"/>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="1. Marktverkenning &amp; Voorbereiding" id="biz-proc-marktverkenning">
      <documentation>Prior Market Consultation (PMC) — IJsselgemeenten engages the market to gather insights on ESB capabilities, pricing, and innovation options before publishing the formal tender. Mandatory market analysis and stakeholder interviews. Outcome: Programma van Eisen (PvE) draft.</documentation>
      <property key="Grondslag" value="Art. 2.47 Aanbestedingswet (marktconsultatie)"/>
      <property key="Doorlooptijd (indicatief)" value="8 weken"/>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="2. Specificatie &amp; Bestekopstelling" id="biz-proc-specificatie">
      <documentation>Drafting of the procurement specification: Selectieleidraad, Beschrijvend Document, Programma van Eisen (PvE), DPIA, and model contract (raamovereenkomst). Must comply with the technical neutrality requirement (art. 2.76 Aanbestedingswet) and GDPR/BIO requirements.</documentation>
      <property key="Deliverables" value="Selectieleidraad · Beschrijvend Document · PvE · Model ROK · DPIA"/>
      <property key="Doorlooptijd (indicatief)" value="10 weken"/>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="3. Publicatie Aankondiging" id="biz-proc-aankondiging">
      <documentation>Publication of the Contract Notice (Aankondiging van Opdracht) on TenderNed and TED/OJEU. Opens the official tender procedure. The notice includes the CPV code, estimated contract value, selection criteria, and deadline for tender submission.</documentation>
      <property key="CPV Code" value="72316000-3 / 48000000-8"/>
      <property key="Proceduretype" value="Niet-openbare procedure of Openbare procedure"/>
      <property key="Grondslag" value="Art. 2.61 Aanbestedingswet / EU Directive 2014/24/EU Art. 49"/>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="4. Nota van Inlichtingen (Q&amp;A)" id="biz-proc-nota">
      <documentation>Structured Q&amp;A process: tenderers submit written questions; the contracting authority publishes consolidated answers (Nota van Inlichtingen) to all participants simultaneously, ensuring equal treatment (gelijke behandeling).</documentation>
      <property key="Publicatie" value="TenderNed — gelijktijdig aan alle deelnemers"/>
      <property key="Grondslag" value="Art. 2.105 Aanbestedingswet — transparantiebeginsel"/>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="5. Inschrijvingsfase" id="biz-proc-inschrijving">
      <documentation>Tenderers prepare and submit their bids digitally via TenderNed before the closing deadline. Submissions include price proposals, technical plans, references, UEA (Uniform European Self-Declaration), and DPIA responses.</documentation>
      <property key="UEA" value="Uniform Europees Aanbestedingsdocument (art. 2.85 Aanbestedingswet)"/>
      <property key="Termijn (indicatief)" value="Minimaal 35 dagen (openbare procedure) / 30 dagen (niet-openbaar)"/>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="6. Beoordeling &amp; Rangschikking" id="biz-proc-beoordeling">
      <documentation>The evaluation committee assesses submissions on pre-published award criteria (gunningscriteria) using the BPKV methodology. Scoring includes price, technical quality, implementation plan, SLA compliance, and security maturity.</documentation>
      <property key="Gunningscriterium" value="BPKV — prijs 40% · kwaliteit 60%"/>
      <property key="Kwaliteitscriteria" value="Integratiearchitectuur · SLA · Migratie · Security · Innovatie"/>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="7. Gunningsbeslissing &amp; Alcatel" id="biz-proc-gunning">
      <documentation>The contracting authority notifies all tenderers of the provisional award decision (voorlopige gunningsbeslissing). A mandatory standstill period (Alcatel-termijn) of at least 20 days applies before the contract is signed.</documentation>
      <property key="Alcatel-termijn" value="Minimaal 20 kalenderdagen (art. 2.127 Aanbestedingswet)"/>
      <property key="Rechtsbescherming" value="Kort geding bij de rechtbank"/>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="8. Contractsluiting &amp; Onboarding" id="biz-proc-contractsluiting">
      <documentation>Signing of the framework agreement (raamovereenkomst) with the winning supplier. Followed by project kick-off, onboarding, and transition planning for the ESB implementation.</documentation>
      <property key="Contractvorm" value="Raamovereenkomst (max. 4 jaar, art. 2.140 Aanbestedingswet)"/>
      <property key="Startdatum implementatie" value="Na definitieve gunning"/>
    </element>
    <element xsi:type="archimate:BusinessFunction" name="Definiëren Gunningscriteria" id="biz-func-gunningscriteria">
      <documentation>Organisational function responsible for determining measurable and legally defensible award criteria based on strategic objectives. Criteria must be pre-published and may not be changed after publication.</documentation>
    </element>
    <element xsi:type="archimate:BusinessFunction" name="Contract- &amp; SLA-monitoring" id="biz-func-contractmonitoring">
      <documentation>Ongoing monitoring of contractual obligations, SLA performance (uptime, response times, incident resolution), and compliance with BIO/AVG requirements post-contract award.</documentation>
    </element>
    <element xsi:type="archimate:BusinessEvent" name="Aankondiging Gepubliceerd (TED/TenderNed)" id="biz-event-aankondiging">
      <documentation>Triggering event: contract notice is published on TED (EU) and TenderNed (NL). This formally opens the tender procedure and starts the submission deadline clock.</documentation>
    </element>
    <element xsi:type="archimate:BusinessEvent" name="Voorlopige Gunningsbeslissing Verzonden" id="biz-event-gunning">
      <documentation>Award decision dispatched to all tenderers simultaneously. Starts the Alcatel standstill period.</documentation>
    </element>
    <element xsi:type="archimate:BusinessService" name="Aanbestedingsdienst" id="biz-svc-aanbestedingsdienst">
      <documentation>Service provided by the procurement unit: end-to-end management of the procurement procedure in compliance with EU and national regulations.</documentation>
    </element>
    <element xsi:type="archimate:BusinessService" name="Beoordelingsdienst" id="biz-svc-beoordelingsdienst">
      <documentation>Independent and auditable evaluation service: assessment of all submitted tenders against pre-published criteria, producing a ranked scoring report.</documentation>
    </element>
    <element xsi:type="archimate:BusinessService" name="Contractmanagementdienst" id="biz-svc-contractmgmtsvc">
      <documentation>Post-award service: managing the contract lifecycle, SLA performance reviews, change requests, and supplier relationship management.</documentation>
    </element>
    <element xsi:type="archimate:Contract" name="ESB Raamovereenkomst" id="biz-contract-rok">
      <documentation>Framework agreement (raamovereenkomst) for the delivery, implementation, hosting, and maintenance of the ESB solution. Maximum duration 4 years (2+1+1). Includes model SLA, data processing agreement (verwerkersovereenkomst AVG), and exit provisions.</documentation>
      <property key="Looptijd" value="2 jaar + 2 x 1 jaar optie (max. 4 jaar)"/>
      <property key="Type" value="Raamovereenkomst met één opdrachtnemer"/>
    </element>
    <element xsi:type="archimate:Contract" name="Verwerkersovereenkomst (AVG/GDPR)" id="biz-contract-vwo">
      <documentation>Data Processing Agreement (DPA) required under GDPR Art. 28. Governs how the ESB supplier processes personal data on behalf of IJsselgemeenten as the data controller.</documentation>
      <property key="Grondslag" value="AVG Art. 28 / GDPR Art. 28"/>
    </element>
    <element xsi:type="archimate:BusinessObject" name="Programma van Eisen (PvE)" id="biz-obj-pve">
      <documentation>Functional and non-functional requirements specification for the ESB solution. Includes integration requirements, performance SLAs, security baselines (BIO), API standards, and interoperability with existing municipal systems (zaaksysteem, HRM, financien).</documentation>
      <property key="Bevat" value="Functionele eisen · NFR's · BIO-eisen · API-standaarden (REST/SOAP) · Migratie-eisen"/>
    </element>
    <element xsi:type="archimate:BusinessObject" name="Uniform Europees Aanbestedingsdocument (UEA)" id="biz-obj-uea">
      <documentation>Standardised EU self-declaration form submitted by tenderers as initial evidence of their suitability. Final evidence is requested from the winning bidder only.</documentation>
      <property key="Grondslag" value="Art. 2.85-2.87 Aanbestedingswet / EU Directive 2014/24/EU Art. 59"/>
    </element>
    <element xsi:type="archimate:BusinessObject" name="Nota van Inlichtingen" id="biz-obj-nvi">
      <documentation>Official Q&amp;A document published during the tender period. All questions and answers are public and binding on the contracting authority. Forms part of the tender specification.</documentation>
    </element>
    <element xsi:type="archimate:BusinessObject" name="Inschrijving (Tender Bid)" id="biz-obj-inschrijving">
      <documentation>The formal tender submission by a market party, consisting of a price proposal, technical plan, references, UEA, DPIA response, and SLA proposal.</documentation>
    </element>
    <element xsi:type="archimate:Representation" name="Aankondiging van Opdracht (TED/OJEU)" id="biz-rep-aankondiging">
      <documentation>Official contract notice published in the EU Official Journal Supplement (TED — Tenders Electronic Daily). Mandatory for contracts above the EU procurement threshold.</documentation>
      <property key="Formulier" value="eForms CN — subtype 16 (standaardomschrijving diensten/leveringen)"/>
    </element>
    <element xsi:type="archimate:Representation" name="Beschrijvend Document / Bestek" id="biz-rep-bestek">
      <documentation>The full tender specification document published to tenderers. Contains requirements, evaluation criteria, procedure rules, model contract, DPIA requirements, and submission instructions.</documentation>
    </element>
    <element xsi:type="archimate:Product" name="ESB Integratiedienstenpakket" id="biz-product-esb">
      <documentation>The product/service bundle being procured: ESB platform software, implementation services, hosting, maintenance, training, and support — delivered under the framework agreement.</documentation>
      <property key="Inhoudt" value="Licenties · Implementatie · Beheer · Support · Opleiding"/>
    </element>
  </folder>
  <folder name="Application" id="id-4x8hcsgl63hr5" type="application">
    <element xsi:type="archimate:ApplicationComponent" name="ESB Platform (Enterprise Service Bus)" id="app-comp-esb">
      <documentation>Core middleware platform that provides message-based integration between internal and external systems. Must support open standards (REST, SOAP, AMQP, MQTT, JMS), have HA/DR capabilities, and comply with BIO security baseline.</documentation>
      <property key="Standaarden" value="REST · SOAP/WS · AMQP · JMS · SFTP · AS4 (Digipoort)"/>
      <property key="Certificering" value="ISO 27001 leverancier · BIO niveau 2"/>
      <property key="Deploymentmodel" value="On-premise NL / Private Cloud NL (Europees datacentrum)"/>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="API Gateway" id="app-comp-apigateway">
      <documentation>Manages and secures all API traffic in and out of the ESB. Provides rate limiting, authentication (OAuth 2.0/PKCE, mTLS), versioning, and developer portal. Must support NLX (Common Ground) for municipality interoperability.</documentation>
      <property key="Standaarden" value="OAuth 2.0 · OpenID Connect · OpenAPI 3.x · NLX"/>
      <property key="Authenticatie" value="DigiD koppeling · eHerkenning · PKIoverheid certificaten"/>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="Message Broker" id="app-comp-messagebroker">
      <documentation>Asynchronous messaging component for reliable event-driven integration. Supports publish/subscribe and point-to-point patterns. Guarantees at-least-once or exactly-once delivery depending on the integration scenario.</documentation>
      <property key="Patronen" value="Pub/Sub · Point-to-Point · Request/Reply · Dead Letter Queue"/>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="Identity &amp; Access Management (IAM)" id="app-comp-iam">
      <documentation>Manages service identities, API keys, certificates, and role-based access control for all integrations. Integrates with IJsselgemeenten's existing Active Directory / Azure AD.</documentation>
      <property key="Protocol" value="SAML 2.0 · OAuth 2.0 · LDAP/AD"/>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="Monitoring &amp; Management Console" id="app-comp-monitoring">
      <documentation>Centralised dashboard for real-time monitoring of message flows, error rates, latency, SLA compliance, and audit trails. Provides alerting and SLA reporting.</documentation>
      <property key="SLA-indicatoren" value="Uptime &gt;= 99,9% · Responsetijd &lt; 500ms · Foutpercentage &lt; 0,1%"/>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="Integration Development Environment (IDE)" id="app-comp-ide">
      <documentation>Low-code / full-code development tooling for building, testing, and deploying integration flows. Includes version control integration (Git), test harnesses, and CI/CD pipeline support.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationCollaboration" name="ESB Integratieplatform (Samenwerking)" id="app-collab-integration">
      <documentation>Collaborative integration between the ESB Platform, API Gateway, Message Broker, IAM, and Monitoring components to deliver end-to-end integration services.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationInterface" name="REST/JSON API Interface" id="app-iface-rest">
      <documentation>Primary synchronous integration interface using HTTP/REST and JSON payloads. Follows OpenAPI 3.x specifications and Common Ground API design rules.</documentation>
      <property key="Standaard" value="OpenAPI 3.x · Common Ground API Design Rules"/>
    </element>
    <element xsi:type="archimate:ApplicationInterface" name="SOAP/WS Interface" id="app-iface-soap">
      <documentation>Legacy SOAP web service interface for integration with older back-office systems (e.g. GBA, BRP-koppeling). Must support WS-Security with PKIoverheid certificates.</documentation>
      <property key="Protocol" value="SOAP 1.1/1.2 · WSDL · WS-Security · WS-ReliableMessaging"/>
    </element>
    <element xsi:type="archimate:ApplicationInterface" name="Digipoort / AS4 Interface" id="app-iface-digipoort">
      <documentation>Standard government-to-government messaging interface via Logius Digipoort, used for e-invoicing (NEN 2380), reporting to central government, and StUF/SuwiML message exchange.</documentation>
      <property key="Berichten" value="AS4 · StUF · SuwiML · Aangifte OB (Belastingdienst)"/>
    </element>
    <element xsi:type="archimate:ApplicationFunction" name="Message Routing &amp; Transformation" id="app-func-routing">
      <documentation>Core ESB function: routes messages between source and target systems based on content, headers, or rules; transforms data formats (XSLT, JSON mapping, canonical model). Supports dynamic and content-based routing.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationFunction" name="Service Orchestration" id="app-func-orchestration">
      <documentation>Coordinates multiple services in a defined sequence to implement complex integration scenarios. Used for multi-step municipal process flows.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationFunction" name="Beveiligingsfunctie (Encryptie &amp; Authenticatie)" id="app-func-security">
      <documentation>Enforces message-level and transport-level security: TLS 1.3, message signing, payload encryption, and token validation. Aligned with BIO and NEN-ISO/IEC 27001.</documentation>
      <property key="BIO Maatregel" value="BIO 12 (Cryptografie) · BIO 9 (Toegangsbeveiliging)"/>
    </element>
    <element xsi:type="archimate:ApplicationFunction" name="Logging, Auditing &amp; Rapportage" id="app-func-logging">
      <documentation>Generates immutable audit logs for all message exchanges. Supports SIEM integration and produces SLA performance reports. Retention policy aligned with AVG bewaarbeleid.</documentation>
      <property key="Bewaartermijn" value="Conform AVG/Archiefwet — minimum 5 jaar voor auditdoeleinden"/>
    </element>
    <element xsi:type="archimate:ApplicationProcess" name="Berichtverwerking (Message Processing)" id="app-proc-berichtverwerking">
      <documentation>End-to-end process flow for a single message: receive → validate schema → authenticate → route → transform → deliver → acknowledge → log.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationProcess" name="API Lifecycle Management" id="app-proc-apilcm">
      <documentation>Process for managing API versions: design, publish, deprecate, retire. Ensures backward compatibility and gives consumers sufficient notice before API changes.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationService" name="Integratieservice" id="app-svc-integratie">
      <documentation>Core application service: reliable, secure, and auditable routing and transformation of data between connected municipal systems.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationService" name="Beveiligingsservice" id="app-svc-security">
      <documentation>Security service providing authentication, authorisation, and encryption for all integration flows.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationService" name="Monitoring &amp; SLA Rapportageservice" id="app-svc-monitoring">
      <documentation>Provides real-time and historical SLA dashboards, alerting, and automated reports for IJsselgemeenten contract management.</documentation>
    </element>
    <element xsi:type="archimate:ApplicationEvent" name="SLA Drempelwaarde Overschreden" id="app-event-sla-breach">
      <documentation>Automated event triggered when an SLA threshold (uptime, response time, error rate) is breached. Initiates alerting and incident management process.</documentation>
    </element>
    <element xsi:type="archimate:DataObject" name="Berichtschema's &amp; Canonical Data Model" id="app-data-schema">
      <documentation>Standardised message schemas (XSD, JSON Schema, Avro) and the canonical data model used for transformation within the ESB. Aligned with StUF, RSGB, RGBZ, and Common Ground standards.</documentation>
      <property key="Standaarden" value="StUF · RSGB · RGBZ · GFO Zaken · NL-API Design Rules"/>
    </element>
    <element xsi:type="archimate:DataObject" name="API Specificaties (OpenAPI/WSDL)" id="app-data-apispec">
      <documentation>Machine-readable API specifications published in the developer portal. All APIs must be documented in OpenAPI 3.x (REST) or WSDL 1.1/2.0 (SOAP).</documentation>
    </element>
    <element xsi:type="archimate:DataObject" name="Audit Log &amp; Verwerkingsregister" id="app-data-auditlog">
      <documentation>Immutable log of all message exchanges including sender, receiver, timestamp, message ID, and processing result. Also serves as part of the AVG verwerkingsregister (Art. 30 GDPR).</documentation>
      <property key="AVG" value="Verwerkingsregister Art. 30 AVG"/>
    </element>
    <element xsi:type="archimate:DataObject" name="SLA Rapportage" id="app-data-slarapport">
      <documentation>Monthly and quarterly SLA performance reports delivered to IJsselgemeenten. Includes uptime, latency, error rates, incident statistics, and change request overview.</documentation>
    </element>
  </folder>
  <folder name="Technology" id="id-w4taspxz2v4tu" type="technology">
    <element xsi:type="archimate:Node" name="Productieomgeving (ESB Cluster)" id="tech-node-prod">
      <documentation>Production environment running the ESB platform in a high-availability cluster configuration. Must be hosted in the Netherlands (EU data residency requirement). Minimum 2 nodes for active-active HA.</documentation>
      <property key="Locatie" value="Nederlands / EU datacentrum"/>
      <property key="HA vereiste" value="Actief-Actief · Uptime SLA &gt;= 99,9%"/>
      <property key="Beveiliging" value="ISO 27001 datacentrum"/>
    </element>
    <element xsi:type="archimate:Node" name="Acceptatieomgeving" id="tech-node-acc">
      <documentation>Acceptance / pre-production environment for integration testing, UAT, and change validation before deploying to production.</documentation>
    </element>
    <element xsi:type="archimate:Node" name="Ontwikkel- &amp; Testomgeving" id="tech-node-dev">
      <documentation>Development and unit test environment for IJsselgemeenten integration developers and the supplier's development team.</documentation>
    </element>
    <element xsi:type="archimate:Device" name="Application Servers (x86-64)" id="tech-device-server">
      <documentation>Physical or virtual servers running the ESB platform. Must support containerisation (Kubernetes/Docker) for scalability and immutable infrastructure deployments.</documentation>
      <property key="Platform" value="Kubernetes (CNCF-compliant) / VM (VMware/KVM)"/>
    </element>
    <element xsi:type="archimate:Device" name="Persistent Storage (NAS/SAN)" id="tech-device-storage">
      <documentation>Persistent storage for message queues, audit logs, and configuration data. Must support encryption at rest (AES-256). Backup to geographically separate location.</documentation>
      <property key="Encryptie" value="AES-256 at rest"/>
      <property key="Backup RTO/RPO" value="RTO &lt; 4 uur · RPO &lt; 1 uur"/>
    </element>
    <element xsi:type="archimate:SystemSoftware" name="Container Platform (Kubernetes / OpenShift)" id="tech-sw-os">
      <documentation>Container orchestration platform for deploying and scaling ESB components. Must support automated failover, rolling updates, and blue/green deployments.</documentation>
    </element>
    <element xsi:type="archimate:SystemSoftware" name="Load Balancer / Reverse Proxy" id="tech-sw-lb">
      <documentation>Distributes incoming traffic across ESB nodes. Provides SSL termination, health checks, and DDoS protection layer.</documentation>
    </element>
    <element xsi:type="archimate:SystemSoftware" name="Firewall / WAF" id="tech-sw-firewall">
      <documentation>Next-generation firewall and Web Application Firewall protecting the ESB cluster. Must comply with BIO network security controls.</documentation>
      <property key="BIO" value="BIO 13 (Communicatiebeveiliging) · BIO 14 (Systeemacquisitie)"/>
    </element>
    <element xsi:type="archimate:CommunicationNetwork" name="GemeenteNet / Diginetwerk" id="tech-net-gemeente">
      <documentation>Secure private network interconnecting IJsselgemeenten locations and providing connectivity to central government services via Diginetwerk (Logius).</documentation>
      <property key="Beheerder" value="Logius / VNG Realisatie"/>
    </element>
    <element xsi:type="archimate:CommunicationNetwork" name="Internet (TLS-beveiligd)" id="tech-net-internet">
      <documentation>Internet connectivity for external API consumers, citizen-facing integrations, and cloud services. All traffic encrypted with TLS 1.3 minimum.</documentation>
      <property key="Minimale TLS versie" value="TLS 1.3 (NCSC TLS Richtlijnen)"/>
    </element>
    <element xsi:type="archimate:Path" name="Beveiligde Verbinding (mTLS / PKIoverheid)" id="tech-path-tls">
      <documentation>Mutual TLS (mTLS) communication path between ESB components and connected back-office systems. Uses PKIoverheid certificates for mutual authentication.</documentation>
      <property key="Certificaten" value="PKIoverheid Private Services Server G1/G2"/>
    </element>
    <element xsi:type="archimate:TechnologyService" name="Managed Hosting Service" id="tech-svc-hosting">
      <documentation>Managed infrastructure service for running the ESB platform including OS patching, hardware maintenance, and datacenter operations. SLA: 99.9% uptime, 24/7 NOC monitoring.</documentation>
    </element>
    <element xsi:type="archimate:TechnologyService" name="Disaster Recovery Service" id="tech-svc-dr">
      <documentation>DR service ensuring business continuity in case of primary site failure. Warm standby at secondary NL datacenter. RTO &lt; 4 hours, RPO &lt; 1 hour.</documentation>
      <property key="RTO" value="&lt; 4 uur"/>
      <property key="RPO" value="&lt; 1 uur"/>
    </element>
    <element xsi:type="archimate:TechnologyService" name="Backup &amp; Restore Service" id="tech-svc-backup">
      <documentation>Daily automated backups of all ESB configuration, message queues, and audit logs. Restore capability tested quarterly.</documentation>
    </element>
    <element xsi:type="archimate:TechnologyFunction" name="High Availability &amp; Failover" id="tech-func-ha">
      <documentation>Automated failover mechanism ensuring the ESB platform remains operational when individual nodes fail. Active-active clustering with no single point of failure.</documentation>
    </element>
    <element xsi:type="archimate:TechnologyFunction" name="Patch &amp; Vulnerability Management" id="tech-func-patching">
      <documentation>Systematic patching of OS, middleware, and application components. Critical patches within 24 hours per BIO. Coordinated with IJsselgemeenten change management.</documentation>
      <property key="BIO Maatregel" value="BIO 12.6 (Technisch beheer van kwetsbaarheden)"/>
    </element>
    <element xsi:type="archimate:TechnologyProcess" name="Incident Management (ITIL)" id="tech-proc-incidentmgmt">
      <documentation>ITIL-aligned incident management process for the ESB platform. P1 incidents (production outage) require 1-hour response and 4-hour resolution per SLA. 24/7 on-call support required.</documentation>
      <property key="SLA P1" value="Reactietijd 1 uur · Hersteltijd 4 uur · 24/7"/>
      <property key="SLA P2" value="Reactietijd 4 uur · Hersteltijd 8 uur · werkdagen"/>
    </element>
    <element xsi:type="archimate:TechnologyProcess" name="Change Management (ITIL)" id="tech-proc-changemgmt">
      <documentation>Controlled change management process for ESB configuration and infrastructure changes. Standard changes require 5-business-day notice; emergency changes require CAB approval from IJsselgemeenten.</documentation>
    </element>
    <element xsi:type="archimate:TechnologyEvent" name="Infrastructuurincident Gedetecteerd" id="tech-event-incident">
      <documentation>Monitoring event triggered when infrastructure anomaly or failure is detected. Initiates the incident management process.</documentation>
    </element>
    <element xsi:type="archimate:Artifact" name="Deployment Package (Container Image)" id="tech-artifact-deploy">
      <documentation>Versioned, immutable container image for the ESB platform and its components. Stored in a private container registry. Built via CI/CD pipeline with automated security scanning (SAST/DAST, CVE scanning).</documentation>
      <property key="Registry" value="Private OCI-compliant registry"/>
      <property key="Security Scan" value="SAST · DAST · SCA (SBOM)"/>
    </element>
    <element xsi:type="archimate:Artifact" name="Infrastructuurconfiguratie (IaC)" id="tech-artifact-config">
      <documentation>Infrastructure-as-Code configuration (Terraform, Ansible, Helm charts) defining the complete ESB platform infrastructure. Versioned in Git. Enables reproducible deployments.</documentation>
    </element>
    <element xsi:type="archimate:Artifact" name="Database Artifact (Configuratie &amp; State)" id="tech-obj-db">
      <documentation>Relational or NoSQL database storing ESB runtime configuration, routing rules, transformation mappings, and operational state. Must support encryption at rest and point-in-time recovery. Modelled as Artifact (Archi 4.x technology passive structure).</documentation>
      <property key="Subtype" value="Database"/>
    </element>
    <element xsi:type="archimate:Artifact" name="Message Queue Artifact (Persistent)" id="tech-obj-queue">
      <documentation>Persistent message queue ensuring guaranteed message delivery. Messages survive node restarts. Supports DLQ (Dead Letter Queue) for failed messages. Modelled as Artifact (Archi 4.x technology passive structure).</documentation>
      <property key="Subtype" value="Message Queue"/>
    </element>
  </folder>

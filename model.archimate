  <folder name="Strategy" id="id-f49a73cb2c9e" type="strategy"/>
  <folder name="Business" id="id-c8fde4672c29" type="business">
    <element xsi:type="archimate:BusinessActor" name="Customer" id="id-577d01512036">
      <documentation>End user interacting with the platform</documentation>
      <property key="Tags" value="core, external"/>
      <property key="Status" value="Active"/>
    </element>
    <element xsi:type="archimate:BusinessRole" name="Account Manager" id="id-a7c7376199ff">
      <documentation>Internal role managing customer accounts</documentation>
      <property key="Tags" value="internal"/>
      <property key="Status" value="Active"/>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="Order Management" id="id-9cb289c6ff31">
      <documentation>Process for handling customer orders end-to-end</documentation>
      <property key="Tags" value="core"/>
      <property key="Status" value="Active"/>
    </element>
    <element xsi:type="archimate:BusinessService" name="Product Catalog Service" id="id-ed4a81565e93">
      <documentation>Provides product information to customers</documentation>
      <property key="Tags" value="core"/>
      <property key="Status" value="Active"/>
    </element>
    <element xsi:type="archimate:BusinessObject" name="Order" id="id-2700b49e0fa6">
      <documentation>Represents a customer order</documentation>
      <property key="Tags" value="data"/>
      <property key="Status" value="Active"/>
    </element>
  </folder>
  <folder name="Application" id="id-e5bad0fad009" type="application">
    <element xsi:type="archimate:ApplicationComponent" name="Order Management System" id="id-c2423782acea">
      <documentation>Core application for order processing</documentation>
      <property key="Tags" value="core"/>
      <property key="Status" value="Active"/>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="CRM System" id="id-3b98408d0bce">
      <documentation>Customer relationship management platform</documentation>
      <property key="Tags" value="core"/>
      <property key="Status" value="Active"/>
    </element>
    <element xsi:type="archimate:ApplicationComponent" name="API Gateway" id="id-432d02939914">
      <documentation>Central API entry point for all services</documentation>
      <property key="Tags" value="infrastructure"/>
      <property key="Status" value="Active"/>
    </element>
    <element xsi:type="archimate:ApplicationInterface" name="Order API" id="id-65a2e989ec49">
      <documentation>REST API exposing order operations</documentation>
      <property key="Tags" value="api"/>
      <property key="Status" value="Active"/>
    </element>
    <element xsi:type="archimate:DataObject" name="Order Data" id="id-6682d484af6e">
      <documentation>Data entity representing an order record</documentation>
      <property key="Tags" value="data"/>
      <property key="Status" value="Active"/>
    </element>
  </folder>
  <folder name="Technology &amp; Physical" id="id-78a9a4bc3883" type="technology">
    <element xsi:type="archimate:Node" name="Application Server" id="id-34740d7a77d4">
      <documentation>Hosts core business applications</documentation>
      <property key="Tags" value="infrastructure"/>
      <property key="Status" value="Active"/>
    </element>
    <element xsi:type="archimate:Node" name="Database Server" id="id-81c047a2ed3e">
      <documentation>Relational database for transactional data</documentation>
      <property key="Tags" value="infrastructure"/>
      <property key="Status" value="Active"/>
    </element>
    <element xsi:type="archimate:SystemSoftware" name="Kubernetes Cluster" id="id-b58adb91eaf2">
      <documentation>Container orchestration platform</documentation>
      <property key="Tags" value="infrastructure"/>
      <property key="Status" value="Active"/>
    </element>
    <element xsi:type="archimate:CommunicationNetwork" name="Internal Network" id="id-16b2cb52a466">
      <documentation>Internal corporate network</documentation>
      <property key="Tags" value="network"/>
      <property key="Status" value="Active"/>
    </element>
    <element xsi:type="archimate:SystemSoftware" name="PostgreSQL" id="id-7b69c85e7d40">
      <documentation>Primary relational database engine</documentation>
      <property key="Tags" value="database"/>
      <property key="Status" value="Active"/>
    </element>
  </folder>
